{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Dashboard": "Data Source=dashboard.db"
  },
  "Jwt": {
    "Issuer": "transfers-dashboard",
    "Audience": "transfers-dashboard-ui",
    "SigningKey": "CHANGE-ME-in-production-use-a-32+char-random-secret-value",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "RefreshCookieName": "tfx_refresh"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  }
}
